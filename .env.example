# DITO / SoldaDito — variables de entorno (NUNCA commitear .env real)
# Copia este archivo a .env y llena los valores. El app levanta sin llaves
# (el seed usa fallback de roster); las llaves habilitan el sync en vivo.

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=cambia-esto-en-produccion
DATABASE_URL=sqlite:///instance/dito.db

# --- Anthropic (Haiku = triage de anomalías · Sonnet = reportes) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_ANALYST=claude-sonnet-4-6

# Google Sheet KPIs (márgenes/objetivos/cierres históricos)
SPREADSHEET_NAME=

# --- Google Ads API ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# --- Meta / Facebook Ads API ---
FACEBOOK_ADS_ACCESS_TOKEN=
FACEBOOK_ADS_APP_ID=
FACEBOOK_ADS_APP_SECRET=
FACEBOOK_ADS_BUSINESS_ID=
FACEBOOK_ADS_API_VERSION=v21.0

# --- Seed: roster fallback (cuando no hay API en vivo) ---
# Apunta al dito.db legacy SOLO-LECTURA para tomar el roster real de cuentas.
LEGACY_DB_PATH=/Users/charlie/Documents/AI Agents Repository/DITO/instance/dito.db

# --- Notificaciones (F5) ---
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
